# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (64-char hex, AES-256-GCM key for credentials)
ENCRYPTION_KEY=

# QStash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# App URL (used as OAuth redirect_uri base)
NEXT_PUBLIC_APP_URL=http://localhost:4567

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LS_PRO_MONTHLY_VARIANT_ID=        # Lemon Squeezy variant IDs (from product settings)
LS_PRO_YEARLY_VARIANT_ID=
LS_BUSINESS_MONTHLY_VARIANT_ID=
LS_BUSINESS_YEARLY_VARIANT_ID=

# Demo Mode
NEXT_PUBLIC_DEMO_EMAIL=demo@stackpulse.io   # client-visible, used for banner detection
DEMO_USER_PASSWORD=                          # seed script only, never exposed to client
DEMO_RESET_SECRET=                           # reset endpoint + GitHub Actions secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (64-char hex, AES-256-GCM key for credentials)
ENCRYPTION_KEY=

# QStash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# App URL (used as OAuth redirect_uri base)
NEXT_PUBLIC_APP_URL=http://localhost:4567

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=

# Demo Mode
NEXT_PUBLIC_DEMO_EMAIL=demo@stackpulse.io   # client-visible, used for banner detection
DEMO_USER_PASSWORD=                          # seed script only, never exposed to client
DEMO_RESET_SECRET=                           # reset endpoint + GitHub Actions secret
